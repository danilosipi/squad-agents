{
  "name": "@cap/base",
  "version": "0.1.0",
  "private": true,
  "description": "CAP-BASE — schema Prisma fundacional e esqueleto TypeScript (@cap/base). Prisma 6.19.3 fixada para format/validate (incompatível com Prisma 7 CLI global sem prisma.config.ts).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "db:format": "npx prisma format --schema prisma/base.prisma",
    "db:validate": "cross-env DATABASE_URL=postgresql://127.0.0.1:5432/cap_base_prisma_validate?schema=public npx prisma validate --schema prisma/base.prisma",
    "db:generate": "npx prisma generate --schema prisma/base.prisma",
    "db:migrate:dev": "npx prisma migrate dev --schema prisma/base.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema prisma/base.prisma",
    "db:migrate:status": "npx prisma migrate status --schema prisma/base.prisma",
    "db:push:test": "npx prisma db push --schema prisma/base.prisma --skip-generate",
    "db:seed": "tsx src/infrastructure/seed/run-seed.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "@types/node": "^22.15.3",
    "cross-env": "7.0.3",
    "prisma": "6.19.3",
    "tsx": "4.20.3",
    "typescript": "~5.8.3",
    "vitest": "3.2.4"
  }
}
